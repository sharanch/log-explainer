# Copy this file to .env and update the values

# Absolute path to the log file on your machine
# Linux/Mac: LOG_FILE_PATH=/var/log/myapp.log
LOG_FILE_PATH=/absolute/path/to/your/app.log

# Ollama model to use (must already be pulled via: ollama pull <model>)
OLLAMA_MODEL=qwen2.5-coder

# Description of your app (improves explanation quality)
APP_CONTEXT=Python application

# Minimum log severity to display: INFO, WARN, ERROR, CRITICAL
MIN_SEVERITY=INFO
